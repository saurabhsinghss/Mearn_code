<%- include('partials/head') %>
</head>
<body class="bg-gradient-to-r from-blue-50 to-indigo-50 min-h-screen">

<%- include('partials/nav') %>

  <main class="max-w-6xl mx-auto px-4">
    <div class="text-center mt-12">
    <h1 class="text-5xl font-bold text-blue-600 mb-8">Welcome to Hamara airbnb</h1>

    <div class="mt-8">
      <div class="flex flex-wrap -mx-3">
        <% homes.forEach(home => { %>
          <div class="w-full sm:w-1/2 lg:w-1/3 px-3 mb-6">
            <div class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-lg transition-shadow h-full flex flex-col">
              <div class="h-40 bg-gray-100">
                <% if (home.photourl) { %>
                  <img src="<%= home.photourl %>" alt="<%= home.houseName %>" class="w-full h-40 object-cover">
                <% } else { %>
                  <div class="w-full h-40 flex items-center justify-center text-gray-400">No image</div>
                <% } %>
              </div>
              <div class="p-4 flex-1 flex flex-col justify-between">
                <div>
                  <h2 class="text-lg font-semibold text-blue-600"><%= home.houseName %></h2>
                  <p class="text-sm text-gray-500 mt-1"><%= home.location %></p>
                </div>
                <div class="mt-4 flex items-center justify-between">
                  <span class="text-xl font-bold text-gray-800">₹<%= home.price %></span>
                  <div class="flex items-center text-sm text-yellow-500">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 mr-1" viewBox="0 0 20 20" fill="currentColor"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.286 3.966a1 1 0 00.95.69h4.18c.969 0 1.371 1.24.588 1.81l-3.388 2.462a1 1 0 00-.364 1.118l1.287 3.966c.3.921-.755 1.688-1.54 1.118L10 13.347l-3.388 2.462c-.785.57-1.84-.197-1.54-1.118l1.287-3.966a1 1 0 00-.364-1.118L2.607 9.393c-.783-.57-.38-1.81.588-1.81h4.18a1 1 0 00.95-.69L9.05 2.927z"/></svg>
                    <span class="text-gray-700"><%= home.rating %></span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        <% }); %>
      </div>
    </div>
  </div>
  </main>
</body>
</html>